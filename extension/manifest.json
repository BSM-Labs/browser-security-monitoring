{
  "manifest_version": 3,
  "name": "BSM - Browser Security Monitor",
  "version": "1.0",
  "description": "Research prototype: runtime JavaScript API abuse and prompt injection detection.",
  "permissions": ["scripting"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["data-store.js", "hooks.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["injected.js"], "matches": ["<all_urls>"] }
  ]
}